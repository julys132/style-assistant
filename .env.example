# -----------------------------
# Core runtime
# -----------------------------
NODE_ENV=development
PORT=5000

# PostgreSQL (required)
DATABASE_URL=postgresql://stylist:stylist@localhost:5432/style_assistant

# JWT/session signing secret (required in production)
JWT_SECRET=change-me
# SESSION_SECRET=change-me-too

# -----------------------------
# Frontend -> backend API URL
# -----------------------------
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000

# -----------------------------
# CORS (backend)
# Comma-separated list, example:
# CORS_ORIGINS=http://localhost:8081,http://localhost:19006
# -----------------------------
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# -----------------------------
# AI provider (required for styling endpoints)
# -----------------------------
GEMINI_API_KEY=
# or GOOGLE_API_KEY=

# Optional AI tuning
# GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# STYLE_TEXT_MODEL=gemini-3-flash-preview
# STYLE_IMAGE_MODEL=gemini-3.1-flash-image-preview
# If this pipeline is migrated to OpenAI image generation later, prefer:
# OPENAI_STYLE_IMAGE_MODEL=chatgpt-image-latest-high-fidelity (20251216)
# STYLE_IMAGE_SIZE=512x512
# EXPOSE_STYLE_DEBUG_PROMPT=false

# -----------------------------
# Stripe (required only for payments)
# -----------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PUBLIC_WEB_URL=http://localhost:5000

# -----------------------------
# Apple Sign-In / Apple IAP (optional)
# -----------------------------
# APPLE_BUNDLE_ID=com.iulia.muse
# APPLE_SERVICE_ID=
# APPLE_CLIENT_ID=
# EXPO_PUBLIC_APPLE_CLIENT_ID=
# APPLE_SHARED_SECRET=

# -----------------------------
# Google Sign-In / Google Play Billing (optional)
# -----------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_WEB_CLIENT_ID=
# GOOGLE_IOS_CLIENT_ID=
# GOOGLE_ANDROID_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# GOOGLE_PLAY_PACKAGE_NAME=com.iulia.muse
# GOOGLE_PLAY_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
# ALLOW_GOOGLE_IAP_BYPASS=false

# -----------------------------
# Credits/IAP tuning (optional)
# -----------------------------
# DEFAULT_INITIAL_CREDITS=3
# DEV_CREDIT_GRANT_AMOUNT=50
# ENABLE_DEV_CREDIT_GRANTS=true
# IAP_PRODUCT_CREDITS={"com.iulia.muse.credits.5":5}
# APPLE_IAP_PRODUCT_CREDITS={}
# GOOGLE_IAP_PRODUCT_CREDITS={}

# -----------------------------
# Static export/build domain (optional)
# -----------------------------
# DEPLOYMENT_DOMAIN=example.com
# EXPO_PUBLIC_APP_DOMAIN=example.com
